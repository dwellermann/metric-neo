---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Content as ManualContent } from "../../../../../docs/user-manual-de.md";

const metadata = {
  title: "Benutzerhandbuch — Metric Neo",
  description:
    "Vollständiges Benutzerhandbuch für Metric Neo: Installation, erster Start, Profile, Projektile, Optiken, Sitzungen und Chronograph-Einrichtung.",
};
---

<BaseLayout {metadata}>
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-8">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-semibold mb-4"
      >
        Dokumentation
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-2">Benutzerhandbuch</h1>
      <p class="text-muted-foreground">
        Vollständige Anleitung für Metric Neo — von der Installation bis zu fortgeschrittenen Funktionen.
      </p>
    </div>
    <div class="prose prose-invert max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary prose-code:text-emerald-400 prose-pre:bg-card prose-pre:border prose-pre:border-border">
      <ManualContent />
    </div>
  </div>
</BaseLayout>
