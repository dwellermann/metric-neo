---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Content as ChangelogContent } from "../../../../CHANGELOG.md";

const metadata = {
  title: "Changelog — Metric Neo",
  description:
    "Release history and version changes for Metric Neo. See what's new, fixed, and changed in each release.",
};
---

<BaseLayout {metadata}>
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-8">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-semibold mb-4"
      >
        Release History
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-2">Changelog</h1>
      <p class="text-muted-foreground">
        All notable changes to Metric Neo. Follows <a
          href="https://keepachangelog.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary hover:underline">Keep a Changelog</a
        > and <a
          href="https://semver.org"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary hover:underline">Semantic Versioning</a
        >.
      </p>
    </div>
    <div class="prose prose-invert max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary prose-code:text-emerald-400 prose-pre:bg-card prose-pre:border prose-pre:border-border prose-h2:border-b prose-h2:border-border prose-h2:pb-2">
      <ChangelogContent />
    </div>
  </div>
</BaseLayout>
