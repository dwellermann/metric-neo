---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Content as ManualContent } from "../../../../docs/user-manual.md";

const metadata = {
  title: "User Manual — Metric Neo",
  description:
    "Complete user manual for Metric Neo: installation, first launch, managing profiles, projectiles, sights, sessions, and chronograph setup.",
};
---

<BaseLayout {metadata}>
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-8">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-semibold mb-4"
      >
        Documentation
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-2">User Manual</h1>
      <p class="text-muted-foreground">
        Complete guide for Metric Neo — installation through advanced features.
      </p>
    </div>
    <div class="prose prose-invert max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary prose-code:text-emerald-400 prose-pre:bg-card prose-pre:border prose-pre:border-border">
      <ManualContent />
    </div>
  </div>
</BaseLayout>
