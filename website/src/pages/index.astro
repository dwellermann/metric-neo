---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
import WidgetWrapper from "@/components/widgets/WidgetWrapper.astro";
import { Icon } from "astro-icon/components";

const metadata = {
  title: "Metric Neo — Offline-First Chronograph Platform",
  description:
    "Record, manage, and analyze ballistic measurement sessions fully offline. Integrates with LMBR RS232 chronographs. Free & open-source.",
  ignoreTitleTemplate: true,
};

const downloads = [
  {
    os: "Windows 10/11",
    icon: "tabler:brand-windows",
    file: "metric-neo_*_windows_amd64.exe",
    note: "Portable — no installer required",
    iconClass: "text-blue-400",
  },
  {
    os: "Ubuntu 24.04+",
    icon: "tabler:brand-ubuntu",
    file: ".deb package",
    note: "WebKit2GTK 4.1",
    iconClass: "text-orange-400",
  },
  {
    os: "Fedora",
    icon: "lucide:layers",
    file: ".rpm package",
    note: "Tested on Fedora 43",
    iconClass: "text-blue-500",
  },
  {
    os: "Arch Linux",
    icon: "lucide:terminal",
    file: ".pkg.tar.zst",
    note: "via pacman",
    iconClass: "text-cyan-400",
  },
];
---

<BaseLayout {metadata}>
  <Hero
    title={`Offline-First<br class="hidden md:block" /> <span class="bg-linear-to-r from-blue-400 via-emerald-400 to-teal-400 bg-clip-text text-transparent">Chronograph Platform</span>`}
    tagline="v0.1.1 · Alpha · Open Source · MIT"
    description="Record, manage, and analyze ballistic measurement sessions — fully offline. Built for precision shooters and sports archers in the DACH region."
    actions={[
      {
        text: "Download",
        href: siteConfig.socialLinks.releases,
        variant: "primary",
        icon: "lucide:download",
      },
      {
        text: "View on GitHub",
        href: siteConfig.socialLinks.github,
        variant: "secondary",
        icon: "lucide:github",
        ariaLabel: "View Metric Neo on GitHub",
      },
    ]}
  />

  <Features
    tagline="Why Metric Neo"
    title="Built for the Range"
    subtitle="Everything you need to track performance data — no cloud, no subscriptions, no internet."
    features={[
      {
        title: "Offline / Air-Gap Ready",
        description:
          "Works without internet in bunkers, basements, and restricted areas. Zero telemetry, zero cloud dependency.",
        icon: "lucide:wifi-off",
        iconClass: "bg-emerald-500/10 text-emerald-400",
      },
      {
        title: "LMBR Chronograph Integration",
        description:
          "Auto-discovers LMBR chronographs via RS232/USB. Shots are recorded automatically — no manual entry needed.",
        icon: "tabler:cpu",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Inventory Management",
        description:
          "Track rifles, air guns, bows, optics, and ammunition batches. Link profiles and projectiles to sessions.",
        icon: "lucide:package",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Shot Statistics & Analytics",
        description:
          "Real-time calculation of average velocity, standard deviation, extreme spread, and kinetic energy (Joule).",
        icon: "lucide:chart-line",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
      {
        title: "Cross-Platform",
        description:
          "Native builds for Windows 10/11, Ubuntu 24.04+, Fedora, and Arch Linux from a single Go/Wails codebase.",
        icon: "tabler:device-laptop",
        iconClass: "bg-indigo-500/10 text-indigo-400",
      },
      {
        title: "Privacy First",
        description:
          "Your data stays on your machine as human-readable JSON files. No accounts, no analytics, no phone-home.",
        icon: "lucide:shield-check",
        iconClass: "bg-teal-500/10 text-teal-400",
      },
    ]}
  />

  <!-- Download Section -->
  <WidgetWrapper containerClass="max-w-5xl mx-auto" id="download">
    <div class="text-center mb-12">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-semibold mb-4"
      >
        Latest Release
      </div>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Download Metric Neo
      </h2>
      <p class="text-muted-foreground text-lg max-w-xl mx-auto">
        Free, open-source, and portable. No installer required on Windows.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {
        downloads.map((d) => (
          <a
            href={siteConfig.socialLinks.releases}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col gap-3 rounded-2xl border border-border bg-card p-6 transition-all hover:border-primary/40 hover:bg-card/80 hover:shadow-lg hover:shadow-primary/5"
          >
            <Icon name={d.icon} class={`w-8 h-8 ${d.iconClass}`} />
            <div>
              <div class="font-semibold text-foreground">{d.os}</div>
              <div class="text-xs text-muted-foreground mt-0.5">{d.file}</div>
              <div class="text-xs text-muted-foreground/70 mt-1">{d.note}</div>
            </div>
            <div class="mt-auto flex items-center gap-1 text-xs text-primary font-medium group-hover:gap-2 transition-all">
              <Icon name="lucide:download" class="w-3.5 h-3.5" />
              Download
            </div>
          </a>
        ))
      }
    </div>

    <p class="text-center text-sm text-muted-foreground">
      All releases on <a
        href={siteConfig.socialLinks.github + "/releases"}
        target="_blank"
        rel="noopener noreferrer"
        class="text-primary hover:underline">GitHub Releases</a
      > · MIT License · Source code included
    </p>
  </WidgetWrapper>
</BaseLayout>
